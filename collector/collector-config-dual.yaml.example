# Dual export: OTLP → New Relic AND ClickHouse.
# Copy to collector-config-dual.yaml (gitignored), set env vars, rebuild collector
# if needed, then: ./scripts/run-collector-dual.sh
#
# Required env:
#   NEW_RELIC_LICENSE_KEY   — New Relic ingest / license key
#   CLICKHOUSE_ENDPOINT     — e.g. https://<host>.azure.clickhouse.cloud:8443
#   CLICKHOUSE_USER         — e.g. default
#   CLICKHOUSE_PASSWORD     — database password from ClickHouse Cloud → Connect
#
# Optional:
#   CLICKHOUSE_DATABASE     — defaults to "otel" below (exporter creates schema)

receivers:
  otlp:
    protocols:
      http:
        endpoint: 0.0.0.0:4318

processors:
  batch:
    timeout: 10s
    send_batch_size: 1024

exporters:
  otlphttp/newrelic:
    endpoint: https://otlp.nr-data.net
    compression: gzip
    headers:
      api-key: ${env:NEW_RELIC_LICENSE_KEY}

  clickhouse:
    endpoint: ${env:CLICKHOUSE_ENDPOINT}
    username: ${env:CLICKHOUSE_USER}
    password: ${env:CLICKHOUSE_PASSWORD}
    database: otel
    # Windows / corp TLS proxies often break default compress+async HTTPS inserts.
    async_insert: false
    compress: none
    create_schema: true
    ttl: 72h
    timeout: 30s
    tls:
      insecure_skip_verify: true
    traces_table_name: otel_traces
    logs_table_name: otel_logs
    metrics_tables:
      gauge:
        name: otel_metrics_gauge
      sum:
        name: otel_metrics_sum
      summary:
        name: otel_metrics_summary
      histogram:
        name: otel_metrics_histogram
      exponential_histogram:
        name: otel_metrics_exp_histogram
    retry_on_failure:
      enabled: true
      initial_interval: 5s
      max_interval: 30s
      max_elapsed_time: 300s

service:
  telemetry:
    logs:
      level: info
    metrics:
      level: none
  pipelines:
    traces:
      receivers: [otlp]
      processors: [batch]
      exporters: [otlphttp/newrelic, clickhouse]
    metrics:
      receivers: [otlp]
      processors: [batch]
      exporters: [otlphttp/newrelic, clickhouse]
    logs:
      receivers: [otlp]
      processors: [batch]
      exporters: [otlphttp/newrelic, clickhouse]
