# Copy to .env.ebpf (gitignored) and fill in your ClickHouse Cloud credentials.
# Used by docker-compose.ebpf.yml:
#   docker compose -f docker-compose.ebpf.yml --env-file .env.ebpf up --build

CLICKHOUSE_ENDPOINT=https://YOUR-HOST.azure.clickhouse.cloud:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=YOUR-CLICKHOUSE-PASSWORD
